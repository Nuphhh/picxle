# Release signing config for Picxle.
# 1. Copy this file to  android/keystore.properties
# 2. Fill in the values you chose when you created the keystore (Keystore/picxle)
# 3. keystore.properties is gitignored — never commit it, and back it up somewhere safe
#    (a password manager). If you lose it you cannot ship updates to the same app.
#
# storeFile: path to the keystore, relative to the android/app/ folder.
#   The keystore currently lives at  Picxle/Keystore/picxle :
#   android/app -> android -> picxle-app -> Picxle, then into Keystore/
storeFile=../../../Keystore/picxle
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
